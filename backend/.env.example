APP_NAME="GridSense AI Backend"
APP_VERSION="1.0.0"
ENVIRONMENT=local
DEBUG=false

DATABASE_URL=postgresql+asyncpg://gridsense:gridsense@localhost:5432/gridsense_ai
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true

LOG_LEVEL=INFO
LOG_JSON=true
